generator client {
  provider = "prisma-client"
  output   = "../src/core/database/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

// Users model
model Users {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
